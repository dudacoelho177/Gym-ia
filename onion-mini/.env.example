# Onion Mini local configuration

# Auth/session
SECRET_KEY=replace-with-a-long-random-secret
AUTH_SECRET_KEY=replace-with-a-long-random-secret
USER_STORE_PATH=data/auth/users.json
AUTH_USERS_PATH=data/auth/users.json
AUTH_SESSION_TTL_SECONDS=604800
AUTH_PBKDF2_ITERATIONS=600000
OAUTH_STATE_TTL_SECONDS=600

# Google OAuth 2.0 / OpenID Connect
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://127.0.0.1:8501/auth/google/callback
GOOGLE_OIDC_TIMEOUT_SECONDS=10

# LLM provider fallback from Issue #1
LLM_PROVIDER=openrouter
LLM_FALLBACK_PROVIDER=openai
LLM_TIMEOUT_SECONDS=20
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
