# 12-factor: copie para .env e ajuste. Nunca commitar valores reais.

# Banco de dados — Supabase (Postgres). Pegue a Connection String em
# Project Settings > Database > Connection string > URI, e troque o prefixo
# "postgresql://" por "postgresql+psycopg://" (driver psycopg3 do projeto).
# Fallback local sem Supabase/Docker: sqlite:///./gym_ai.db
DATABASE_URL=postgresql+psycopg://postgres.SEU_PROJECT_REF:SUA_SENHA@aws-0-REGIAO.pooler.supabase.com:6543/postgres

# Provider de LLM: OpenRouter (real). Requer chave de API válida.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/auto

# Auth simplificada do MVP: API key estática por tenant (ver core/config.py).
DEV_TENANT_API_KEY=dev-tenant-key
DEV_TENANT_SLUG=clear-it-demo

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
